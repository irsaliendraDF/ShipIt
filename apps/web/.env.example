# ShipIt — shipit.fun + shipit.build environment variables
#
# Copy to .env.local for local dev. In Vercel, set the same vars in
# Project Settings → Environment Variables.
#
# Both vars are NEXT_PUBLIC_* because the anon key is designed to be
# exposed in the browser bundle. Access control is enforced by Supabase
# Row Level Security (see supabase/migrations/*_init_shipit_schema.sql).

NEXT_PUBLIC_SUPABASE_URL=https://whhnkvyyncjsprlpobos.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
